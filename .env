ENVIRONMENT=local
DOTNET_ENVIRONMENT=Development

FRONTEND_BASE_URL=http://localhost:5173
BACKEND_BASE_URL=http://localhost:5000

AZURE_SQL_CONNECTION_STRING=Server=tcp:prodquotesdb.database.windows.net,1433;Initial Catalog=prodquotesdb;Persist Security Info=False;User ID=antonio;Password=!;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;

JWT_SECRET_KEY=dev-jwt-secret-change-me-super-long
